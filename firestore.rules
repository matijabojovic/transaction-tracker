rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function ownerUid(spaceDoc) {
      return ('ownerId' in spaceDoc.data) ? spaceDoc.data.ownerId : spaceDoc.data.uid;
    }

    function roleForSpace(spaceDoc) {
      return (
        ('members' in spaceDoc.data) &&
        (request.auth.uid in spaceDoc.data.members)
      )
        ? spaceDoc.data.members[request.auth.uid].role
        : (isMember(spaceDoc) ? 'owner' : 'none');
    }

    function isOwner(spaceDoc) {
      return signedIn() && request.auth.uid == ownerUid(spaceDoc);
    }

    function canWriteTx(spaceDoc) {
      return roleForSpace(spaceDoc) in ['owner', 'editor'];
    }

    function isMember(spaceDoc) {
      return signedIn() && (
        (
          ('memberUids' in spaceDoc.data) &&
          (request.auth.uid in spaceDoc.data.memberUids)
        ) || (
          ('uid' in spaceDoc.data) &&
          request.auth.uid == spaceDoc.data.uid
        )
      );
    }

    function isSelfLeaveUpdate() {
      return (
        ('memberUids' in resource.data) &&
        ('members' in resource.data) &&
        isMember(resource) &&
        !isOwner(resource) &&
        request.auth.uid in resource.data.memberUids &&
        !(request.auth.uid in request.resource.data.memberUids) &&
        request.resource.data.memberCount == resource.data.memberCount - 1 &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['members', 'memberUids', 'memberCount']) &&
        request.resource.data.members.diff(resource.data.members).affectedKeys().hasOnly([request.auth.uid])
      );
    }

    match /spaces/{spaceId} {
      allow read: if isMember(resource);
      allow create: if signedIn()
        && request.auth.uid == request.resource.data.ownerId
        && request.auth.uid in request.resource.data.memberUids
        && request.resource.data.members[request.auth.uid].role == 'owner';
      allow update: if isOwner(resource) || isSelfLeaveUpdate();
      allow delete: if signedIn() && isOwner(resource);
    }

    match /spaceCodes/{spaceId} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.auth.uid == request.resource.data.ownerId;
      allow update: if signedIn()
        && request.auth.uid == resource.data.ownerId
        && request.resource.data.ownerId == resource.data.ownerId;
      allow delete: if signedIn()
        && request.auth.uid == resource.data.ownerId;
    }

    match /transactions/{txId} {
      allow read: if signedIn()
        && exists(/databases/$(database)/documents/spaces/$(resource.data.spaceId))
        && isMember(get(/databases/$(database)/documents/spaces/$(resource.data.spaceId)));

      allow create: if signedIn()
        && request.auth.uid == request.resource.data.uid
        && exists(/databases/$(database)/documents/spaces/$(request.resource.data.spaceId))
        && canWriteTx(get(/databases/$(database)/documents/spaces/$(request.resource.data.spaceId)))
        && request.resource.data.createdAt is int
        && request.resource.data.updatedAt is int;

      allow update, delete: if signedIn()
        && exists(/databases/$(database)/documents/spaces/$(resource.data.spaceId))
        && canWriteTx(get(/databases/$(database)/documents/spaces/$(resource.data.spaceId)))
        && request.resource.data.spaceId == resource.data.spaceId
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.createdAt == resource.data.createdAt;
    }

    match /spaceJoinRequests/{requestId} {
      allow create: if signedIn()
        && request.auth.uid == request.resource.data.requesterUid
        && request.resource.data.status == 'pending'
        && exists(/databases/$(database)/documents/spaces/$(request.resource.data.spaceId));

      allow read: if signedIn() && (
        request.auth.uid == resource.data.requesterUid ||
        (
          exists(/databases/$(database)/documents/spaces/$(resource.data.spaceId)) &&
          isOwner(get(/databases/$(database)/documents/spaces/$(resource.data.spaceId)))
        )
      );

      allow update: if signedIn() && (
        (
          request.auth.uid == resource.data.requesterUid
          && request.resource.data.requesterUid == resource.data.requesterUid
          && request.resource.data.spaceId == resource.data.spaceId
          && request.resource.data.status == 'pending'
          && request.resource.data.reviewedByUid == resource.data.reviewedByUid
        ) ||
        (
          exists(/databases/$(database)/documents/spaces/$(resource.data.spaceId)) &&
          isOwner(get(/databases/$(database)/documents/spaces/$(resource.data.spaceId))) &&
          request.resource.data.status in ['approved', 'rejected'] &&
          request.resource.data.requesterUid == resource.data.requesterUid &&
          request.resource.data.spaceId == resource.data.spaceId
        )
      );

      allow delete: if signedIn()
        && exists(/databases/$(database)/documents/spaces/$(resource.data.spaceId))
        && isOwner(get(/databases/$(database)/documents/spaces/$(resource.data.spaceId)));
    }

    match /users/{uid}/spacePrefs/{spaceId} {
      allow read, write: if signedIn() && request.auth.uid == uid;
    }
  }
}
